#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/yunu/kodocagent/node_modules/.pnpm/@clazic+kordoc@2.7.6/node_modules/@clazic/kordoc/node_modules:/Users/yunu/kodocagent/node_modules/.pnpm/@clazic+kordoc@2.7.6/node_modules:/Users/yunu/kodocagent/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/yunu/kodocagent/node_modules/.pnpm/@clazic+kordoc@2.7.6/node_modules/@clazic/kordoc/node_modules:/Users/yunu/kodocagent/node_modules/.pnpm/@clazic+kordoc@2.7.6/node_modules:/Users/yunu/kodocagent/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@clazic/kordoc/dist/cli.js" "$@"
else
  exec node  "$basedir/../@clazic/kordoc/dist/cli.js" "$@"
fi
