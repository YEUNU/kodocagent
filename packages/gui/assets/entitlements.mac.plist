<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS 강화된 런타임(hardened runtime) entitlements — 공증(notarization)에 필요.
  Electron + JIT(V8)에 필요한 최소 권한만 부여한다. 네트워크 서버/카메라/마이크 등
  민감 권한은 부여하지 않는다(문서·PII 도구이므로 최소 권한 원칙).

  electron-builder.yml 의 mac.entitlements / mac.entitlementsInherit 에서 이 파일을
  참조하도록 주석을 해제하면 적용된다(인증서 준비 후).
-->
<plist version="1.0">
  <dict>
    <!-- V8 JIT (Electron 필수) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- 일부 네이티브 애드온/동적 로딩에 필요할 수 있음 -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
  </dict>
</plist>
