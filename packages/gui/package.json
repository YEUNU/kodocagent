{
  "name": "@kodocagent/gui",
  "version": "0.4.0",
  "description": "kodocagent Electron 데스크톱 GUI",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "pack": "electron-vite build && electron-builder --dir",
    "publish:gui": "electron-vite build && electron-builder -p onTagOrDraft"
  },
  "dependencies": {
    "@kodocagent/core": "workspace:*",
    "@kodocagent/doc-tools": "workspace:*",
    "@kodocagent/shared": "workspace:*",
    "electron": "^42.4.0",
    "electron-updater": "^6.8.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron-builder": "^26.15.3",
    "electron-vite": "^6.0.0-beta.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
