{
  "name": "@kodocagent/monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "audit": "pnpm audit --prod"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
